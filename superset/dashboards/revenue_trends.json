{
  "dashboard_title": "NYC Taxi - Revenue Trends",
  "description": "Track NYC taxi revenue trends: payment type breakdowns, fare analysis, tipping behavior, and monthly revenue patterns from the gold layer.",
  "published": true,
  "refresh_frequency": 300,
  "color_scheme": "supersetColors",
  "datasets": [
    {"schema": "gold", "table": "revenue_by_payment_type"},
    {"schema": "gold", "table": "daily_trip_stats"}
  ],
  "charts": [
    {
      "slice_name": "Total Revenue",
      "description": "Aggregate revenue across all trips and payment types",
      "viz_type": "big_number_total",
      "dataset": {"schema": "gold", "table": "revenue_by_payment_type"},
      "params": {
        "metric": {"label": "Total Revenue", "expressionType": "SQL", "sqlExpression": "SUM(total_revenue)"},
        "y_axis_format": "$,.2f",
        "header_font_size": 0.4,
        "subheader_font_size": 0.15
      }
    },
    {
      "slice_name": "Average Fare Amount",
      "description": "Average fare per trip",
      "viz_type": "big_number_total",
      "dataset": {"schema": "gold", "table": "daily_trip_stats"},
      "params": {
        "metric": {"label": "Avg Fare", "expressionType": "SQL", "sqlExpression": "AVG(avg_fare)"},
        "y_axis_format": "$,.2f",
        "header_font_size": 0.4,
        "subheader_font_size": 0.15
      }
    },
    {
      "slice_name": "Total Tips",
      "description": "Total tip amount across all trips",
      "viz_type": "big_number_total",
      "dataset": {"schema": "gold", "table": "revenue_by_payment_type"},
      "params": {
        "metric": {"label": "Total Tips", "expressionType": "SQL", "sqlExpression": "SUM(total_tips)"},
        "y_axis_format": "$,.2f",
        "header_font_size": 0.4,
        "subheader_font_size": 0.15
      }
    },
    {
      "slice_name": "Average Tip Percentage",
      "description": "Average tip percentage across trips",
      "viz_type": "big_number_total",
      "dataset": {"schema": "gold", "table": "revenue_by_payment_type"},
      "params": {
        "metric": {"label": "Avg Tip %", "expressionType": "SQL", "sqlExpression": "AVG(avg_tip_percentage)"},
        "y_axis_format": ",.1f",
        "subheader": "%",
        "header_font_size": 0.4,
        "subheader_font_size": 0.15
      }
    },
    {
      "slice_name": "Revenue by Payment Type",
      "description": "Breakdown of total revenue by payment method",
      "viz_type": "pie",
      "dataset": {"schema": "gold", "table": "revenue_by_payment_type"},
      "params": {
        "metric": {"label": "Total Revenue", "expressionType": "SQL", "sqlExpression": "SUM(total_revenue)"},
        "groupby": ["payment_type"],
        "color_scheme": "supersetColors",
        "show_legend": true,
        "show_labels": true,
        "label_type": "key_percent",
        "number_format": "$,.2f",
        "row_limit": 10
      }
    },
    {
      "slice_name": "Trip Count by Payment Type",
      "description": "Number of trips per payment method",
      "viz_type": "pie",
      "dataset": {"schema": "gold", "table": "revenue_by_payment_type"},
      "params": {
        "metric": {"label": "Trip Count", "expressionType": "SQL", "sqlExpression": "SUM(trip_count)"},
        "groupby": ["payment_type"],
        "color_scheme": "supersetColors",
        "show_legend": true,
        "show_labels": true,
        "label_type": "key_percent",
        "number_format": ",d",
        "row_limit": 10
      }
    },
    {
      "slice_name": "Monthly Revenue Trend",
      "description": "Revenue trend by year and month",
      "viz_type": "echarts_timeseries_line",
      "dataset": {"schema": "gold", "table": "revenue_by_payment_type"},
      "params": {
        "x_axis": "month",
        "metrics": [{"label": "Total Revenue", "expressionType": "SQL", "sqlExpression": "SUM(total_revenue)"}],
        "groupby": ["year"],
        "order_desc": false,
        "row_limit": 100,
        "color_scheme": "supersetColors",
        "show_legend": true,
        "x_axis_title": "Month",
        "y_axis_title": "Total Revenue ($)",
        "y_axis_format": "$,.0f"
      }
    },
    {
      "slice_name": "Average Fare by Day of Week",
      "description": "How fares vary across the week",
      "viz_type": "echarts_timeseries_bar",
      "dataset": {"schema": "gold", "table": "daily_trip_stats"},
      "params": {
        "x_axis": "day_of_week",
        "metrics": [
          {"label": "Avg Fare", "expressionType": "SQL", "sqlExpression": "AVG(avg_fare)"},
          {"label": "Min Fare", "expressionType": "SQL", "sqlExpression": "AVG(min_fare)"},
          {"label": "Max Fare", "expressionType": "SQL", "sqlExpression": "AVG(max_fare)"}
        ],
        "groupby": [],
        "order_desc": false,
        "row_limit": 7,
        "color_scheme": "supersetColors",
        "show_legend": true,
        "x_axis_title": "Day of Week (1=Mon, 7=Sun)",
        "y_axis_title": "Fare Amount ($)",
        "y_axis_format": "$,.2f"
      }
    },
    {
      "slice_name": "Average Tips by Payment Type",
      "description": "Tipping behavior by payment method",
      "viz_type": "echarts_timeseries_bar",
      "dataset": {"schema": "gold", "table": "revenue_by_payment_type"},
      "params": {
        "x_axis": "payment_type",
        "metrics": [
          {"label": "Avg Tip Amount", "expressionType": "SQL", "sqlExpression": "AVG(avg_tip_amount)"},
          {"label": "Avg Tip %", "expressionType": "SQL", "sqlExpression": "AVG(avg_tip_percentage)"}
        ],
        "groupby": [],
        "order_desc": true,
        "row_limit": 10,
        "color_scheme": "supersetColors",
        "show_legend": true,
        "x_axis_title": "Payment Type",
        "y_axis_title": "Amount"
      }
    },
    {
      "slice_name": "Payment Type Revenue Details",
      "description": "Detailed breakdown of revenue metrics by payment type",
      "viz_type": "table",
      "dataset": {"schema": "gold", "table": "revenue_by_payment_type"},
      "params": {
        "metrics": [
          {"label": "Trip Count", "expressionType": "SQL", "sqlExpression": "SUM(trip_count)"},
          {"label": "Total Revenue", "expressionType": "SQL", "sqlExpression": "SUM(total_revenue)"},
          {"label": "Avg Total Amount", "expressionType": "SQL", "sqlExpression": "AVG(avg_total_amount)"},
          {"label": "Avg Tip Amount", "expressionType": "SQL", "sqlExpression": "AVG(avg_tip_amount)"},
          {"label": "Total Tips", "expressionType": "SQL", "sqlExpression": "SUM(total_tips)"},
          {"label": "Avg Tip %", "expressionType": "SQL", "sqlExpression": "AVG(avg_tip_percentage)"}
        ],
        "groupby": ["payment_type"],
        "order_desc": true,
        "row_limit": 20,
        "include_search": true
      }
    }
  ],
  "layout": {
    "cols_per_row": 4,
    "kpi_row": [0, 1, 2, 3],
    "chart_rows": [[4, 5], [6, 7], [8, 9]]
  }
}
