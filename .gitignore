# =============================================================================
# NYC Taxi Data Lakehouse — .gitignore
# =============================================================================

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/

# ── Virtual environments ────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ── Environment variables ───────────────────────────────────────────────────
.env
.env.local
.env.production
.envrc

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Testing & coverage ──────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
.tox/
.nox/

# ── Linting & type-checking ─────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pyre/
.pytype/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
bronze_ingestion_full.log

# ── Data files ───────────────────────────────────────────────────────────────
*.csv
*.parquet
*.xlsx

# ── Database files (local development) ──────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Backups ──────────────────────────────────────────────────────────────────
*.sql
!gold/models/**/*.sql
!docker-init-scripts/**/*.sql
*.dump
backup_*/

# ── Temporary files ─────────────────────────────────────────────────────────
*.tmp
*.bak
temp/
.agent/

# ── Docker volumes (local development) ──────────────────────────────────────
pgadmin/data/

# ── Airflow runtime ─────────────────────────────────────────────────────────
airflow/logs/

# ── dbt artifacts ────────────────────────────────────────────────────────────
gold/logs/
gold/target/
gold/dbt_packages/
gold/.user.yml

# ── Superset runtime artifacts ──────────────────────────────────────────────
superset/superset.db
superset/.cache/
superset/.local/

# ── Copilot / AI ─────────────────────────────────────────────────────────────
skill.md
copilot-instruction.md
.github/skills/

# ── PyPI ─────────────────────────────────────────────────────────────────────
.pypirc